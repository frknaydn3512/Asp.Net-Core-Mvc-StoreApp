@model Product

<div class="col-sm-12 col-md-4 my-3 d-flex">
  <div class="card h-100 w-100">
    <div class="card-header text-center">
      @Model.ProductName
    </div>
    <div style="height: 220px; background: #f8f9fa; display: flex; align-items: center; justify-content: center; overflow: hidden; border-bottom: 1px solid rgba(0,0,0,.08);">
      <img src="@Model.ImageUrl" alt="@Model.ProductName"
           style="max-height: 200px; max-width: 100%; object-fit: contain; padding: 12px;">
    </div>
    <div class="card-body d-flex flex-column">
      <div class="card-text">
        <div class="text-danger text-center lead p-2 rounded-2">
          @Model?.Price.ToString("C2")
        </div>
      </div>
      <p class="card-text text-muted small">@Model?.Summary</p>
      <div class="d-flex justify-content-center mt-auto">
        <div class="btn-group">
          <a asp-controller="Product" asp-action="Get" asp-route-id="@Model?.ProductId"
             class="btn btn-outline-secondary rounded-start">
            <i class="fa-solid fa-arrow-right"></i>
          </a>
          <form id="@Model?.ProductId" asp-page="/cart" method="post">
            <input type="hidden" asp-for="ProductId">
            <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()">
            <button type="submit" class="btn btn-outline-secondary rounded-end mx-1">
              <i class="fa fa-cart-plus"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
